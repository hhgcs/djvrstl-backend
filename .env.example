# Ghost CMS
#
# Local development can use the compose defaults without this file.
# For production, copy this file to .env on the VPS and replace every secret.

GHOST_URL=https://blog.djvrstl.com
GHOST_MYSQL_DATABASE=ghost
GHOST_MYSQL_USER=ghost
GHOST_MYSQL_PASSWORD=replace-with-a-long-random-password
GHOST_MYSQL_ROOT_PASSWORD=replace-with-a-different-long-random-password

# Configure transactional email inside Ghost Admin or add SMTP env vars
# when a provider is selected. Do not commit real SMTP credentials.
